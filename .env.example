# Обязательные ключи
BOT_TOKEN=123456:ABC-DEF...
# Ключ Groq API — бесплатно на https://console.groq.com/keys
GROQ_API_KEY=gsk_...

# Необязательные
OPENWEATHER_API_KEY=
# Любой другой OpenAI-совместимый API можно подключить так:
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini
# Модель для разбора фото (по умолчанию Llama 4 Scout на Groq):
# LLM_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
NEWS_RSS_URL=https://lenta.ru/rss/news
NEWS_COUNT=3
TZ_NAME=Europe/Moscow
DB_PATH=assistant.db

# Мини-апп (Telegram Mini App) — необязательно
# Публичный HTTPS-адрес сервера бота; без него кнопка мини-аппа не показывается
WEBAPP_URL=
# Порт встроенного веб-сервера (по умолчанию 8080, либо берётся из PORT хостинга)
WEB_PORT=8080

# Notion — необязательно. Зеркалит задачи, покупки и расходы в базы Notion.
# 1) Создай интеграцию: https://www.notion.so/my-integrations и скопируй токен
# 2) На нужной странице Notion: ... -> Connections -> добавь интеграцию
# 3) Впиши токен ниже и перезапусти бота — базы создадутся сами
NOTION_TOKEN=
